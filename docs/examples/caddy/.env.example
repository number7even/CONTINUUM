# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — DO NOT commit your real token or domain.
#
# Two required values:
#   1. CONTINUUM_DOMAIN          — the public domain (A/AAAA record points at this host)
#   2. CONTINUUM_OPERATOR_EMAIL  — Let's Encrypt account registration email
#   3. CONTINUUM_HTTP_TOKEN      — Bearer shared secret for MCP clients
#
# Generate the token with:
#   openssl rand -hex 32

# ─── Required ────────────────────────────────────────────────────────────────

CONTINUUM_DOMAIN=continuum.example.com
CONTINUUM_OPERATOR_EMAIL=operator@example.com
CONTINUUM_HTTP_TOKEN=replace-with-output-of-openssl-rand-hex-32

# ─── Optional (sensible defaults — only set if you need to override) ────────

# Project ID (subdir under /data for SQLite + ruvector). Default: continuum
# CONTINUUM_PROJECT_ID=continuum

# Storage backend. Default: hybrid (V0.5 SQLite + RuVector). Use `sqlite` to
# opt out of the vector store.
# CONTINUUM_STORAGE_BACKEND=hybrid

# Embedder worker pool size. Default: 1 (set in docker-compose.yml).
# Tune per VPS class — see DEPLOY_SELF_HOSTED.md § "Memory profile per VPS class".
#   512MB VPS  →  1   (default in this compose file)
#   1GB VPS    →  2
#   2GB+ VPS   →  unset (defaults to min(cores, 4))
#   256MB VPS  →  0   (disables pool; inline embed; bulk migration will OOM)
# CONTINUUM_EMBED_WORKERS=1
