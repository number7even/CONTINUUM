{
  "mcpServers": {
    "git-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://gitmcp.io/docs"
      ],
      "env": {}
    },
    "headroom": {
      "type": "stdio",
      "command": "/Users/emporiumcollection/Library/Python/3.11/bin/headroom",
      "args": [
        "mcp",
        "serve"
      ],
      "env": {}
    },
    "continuum": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/Users/emporiumcollection/Development/supabase-projects/CONTINUUM/packages/mcp-server/dist/index.js"
      ],
      "env": {
        "CONTINUUM_PROJECT_ID": "continuum"
      }
    }
  }
}