# AMF worker — environment template (this machine, NOT Vercel).
# Copy to `.env.local` (gitignored, never committed — P1) and fill values:
#   cp apps/amf/worker/.env.local.example apps/amf/worker/.env.local
# Loaded automatically by env.mjs. Every key is OPTIONAL — each seam/provider gates itself
# and fail-safes when its key is absent (P6). Fill only what you're using.

# ── Content quality (turns grounded templates into LLM-authored drafts) ──────────────
ANTHROPIC_API_KEY=                 # LLM-polished post + report drafts (content-matcher). Without it → grounded template.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── XENOS CRM amalgamation (the revenue loop) ────────────────────────────────────────
# Seam ① lead handoff → POST /api/crm/leads/capture, header x-intake-key
XENOS_LEADS_URL=                   # e.g. https://voicecosmos.com
XENOS_LEADS_KEY=                   # scoped intake key XENOS issues
# Seams ⑤ (push draft) + ② (feedback) + return-path → /api/hitl/*, header x-hitl-key
XENOS_HITL_URL=                    # e.g. https://voicecosmos.com
XENOS_HITL_KEY=                    # scoped HITL key XENOS issues
AMF_XENOS_TENANT=                  # default owner tenant_id for polling /api/hitl/recent-decisions

# ── Intelligence providers (mostly key-free; these are the optional ones) ────────────
YOUTUBE_API_KEY=                   # official YouTube Data API v3 (free key) — search + view counts
# RAPIDAPI_KEY=                    # fallback only; prefer the official YOUTUBE_API_KEY
# WORLDMONITOR_API_KEY=            # macro/geopolitics intel (worldmonitor.app), optional
# FEEDLY_ACCESS_TOKEN=             # Feedly Web API (Enterprise-only); free path = RSS/OPML instead
# FEEDLY_STREAM_ID=

# ── L4 audio (voice-over shorts) ─────────────────────────────────────────────────────
# AUPHONIC_API_KEY=                # voice enhance; fail-safe to raw voice without it
# AUPHONIC_PRESET_UUID=

# ── StudioMunich VAULT (rented talent, when live) ────────────────────────────────────
# STUDIOMUNICH_VAULT_URL=
# STUDIOMUNICH_VAULT_SECRET=
# SM_WEBHOOK_SIGNING_SECRET=
# VAULT_RIGHTS_SIGNING_SECRET=

# ── CONTINUUM engine (render ledger / HTTP) ──────────────────────────────────────────
# CONTINUUM_HTTP_URL=
# CONTINUUM_HTTP_TOKEN=

# ── FAL (AI b-roll, dormant) ─────────────────────────────────────────────────────────
FAL_KEY=                           # fal.ai AI b-roll (~$0.02/clip). fal.ai → Dashboard → Keys.
# AMF_TTS=supertonic               # supertonic (default) | voxcpm (needs dedicated 16GB+)
# AMF_LANG=en
