# Copy to .env.local for local dev, or set in Vercel project settings
# (Settings → Environment Variables).
#
# Without these set, the operator dashboard at / renders the "not configured"
# state, and /chat returns 500 from /api/chat.

# ── CONTINUUM engine connection (used by / dashboard AND /chat) ─────────────

# Full URL to the CONTINUUM HTTP/SSE endpoint, including the /sse path.
# Local: http://localhost:7878/sse
# Hosted: https://continuum-engine.fly.dev/sse  (or https://api.continuum.rest/sse)
CONTINUUM_HTTP_URL=https://continuum-engine.fly.dev/sse

# Bearer token used to authenticate against the CONTINUUM HTTP server.
# Must match what fly secrets set CONTINUUM_HTTP_TOKEN=... at the engine.
CONTINUUM_HTTP_TOKEN=replace-with-the-shared-secret

# Optional — pass the project ID the engine should load for this session.
# Defaults to "continuum" if unset (matches the engine's default).
CONTINUUM_PROJECT_ID=continuum

# ── Anthropic API key (required for /chat — NOT for /) ─────────────────────

# Get one at https://console.anthropic.com/settings/keys
# /chat calls Claude Sonnet 4.6 via @ai-sdk/anthropic. Without this, the
# chat route returns 500 (the operator dashboard at / does not depend on it).
ANTHROPIC_API_KEY=sk-ant-...
