# Copy to .env.local for local dev, or set in Vercel project settings
# (Settings → Environment Variables).
#
# Required to actually connect — without these, the console renders the
# "not configured" state on every request.

# Full URL to the CONTINUUM HTTP/SSE endpoint, including the /sse path.
# Local: http://localhost:7878/sse
# Hosted: https://your-engine-host/sse
CONTINUUM_HTTP_URL=http://localhost:7878/sse

# Bearer token used to authenticate against the CONTINUUM HTTP server.
# Must match the $CONTINUUM_HTTP_TOKEN the engine was started with.
CONTINUUM_HTTP_TOKEN=replace-with-the-shared-secret

# Optional — pass the project ID the engine should load for this session.
# Defaults to whatever $CONTINUUM_PROJECT_ID the engine was launched with.
CONTINUUM_PROJECT_ID=continuum
