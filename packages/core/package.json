{
  "name": "@continuum/core",
  "version": "0.0.1",
  "description": "Continuum core — data types, SQLite schema, checkpoint engine, observation indexer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./db": {
      "import": "./dist/db.js",
      "types": "./dist/db.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./checkpoint": {
      "import": "./dist/checkpoint.js",
      "types": "./dist/checkpoint.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --test",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.3.0",
    "ruvector": "^0.2.25"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  },
  "license": "Apache-2.0",
  "author": "Riaan Kleynhans <riaan@number7even.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/number7even/CONTINUUM.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
