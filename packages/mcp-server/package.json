{
  "name": "@continuum/mcp-server",
  "version": "0.0.1",
  "description": "Continuum MCP server — exposes 7 tools + 4 Resources + 2 Prompts to AI clients over stdio (local) or HTTP/SSE (remote / hosted).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "continuum-mcp": "./dist/index.js",
    "continuum-mcp-http": "./dist/http.js"
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "serve": "node dist/http.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@continuum/core": "0.0.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21"
  },
