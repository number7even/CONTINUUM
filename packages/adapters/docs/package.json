{
  "name": "@continuum/adapter-docs",
  "version": "0.0.1",
  "description": "Continuum docs adapter — ingests local /docs markdown into the Continuum observation index. Idempotent stable IDs per file path.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "continuum-adapter-docs": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "node --test",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@continuum/core": "0.0.1",
    "ruv-swarm": "^1.0.20"
  },
  "license": "Apache-2.0",
  "author": "Riaan Kleynhans <riaan@number7even.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/number7even/CONTINUUM.git",
    "directory": "packages/adapters/docs"
  }
}
